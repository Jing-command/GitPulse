{
  "name": "@gitpulse/cli",
  "version": "1.0.0",
  "description": "GitPulse 命令行工具 - 技术内容自动化生成",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "gitpulse": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rimraf dist"
  },
  "keywords": [
    "gitpulse",
    "cli",
    "git",
    "changelog",
    "documentation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@gitpulse/core": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "conf": "^12.0.0",
    "inquirer": "^9.2.12",
    "ora": "^8.0.1",
    "simple-git": "^3.22.1",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.5",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
