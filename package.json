{
  "name": "gitpulse",
  "version": "1.0.0",
  "description": "技术内容全自动流水线 - 深度解析 Git 代码变更，自动生成更新日志、技术博客和文档",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @gitpulse/web dev",
    "dev:api": "pnpm --filter @gitpulse/api dev",
    "dev:cli": "pnpm --filter @gitpulse/cli dev",
    "lint": "eslint packages --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint packages --ext .ts,.tsx --fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,json,md}\"",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "clean": "pnpm -r clean",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @gitpulse/core db:generate",
    "db:push": "pnpm --filter @gitpulse/core db:push",
    "db:migrate": "pnpm --filter @gitpulse/core db:migrate",
    "db:seed": "pnpm --filter @gitpulse/core db:seed",
    "db:studio": "pnpm --filter @gitpulse/core db:studio",
    "cli": "node packages/cli/dist/index.js"
  },
  "keywords": [
    "git",
    "changelog",
    "documentation",
    "ai",
    "automation",
    "vitepress",
    "seo"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@8.15.1"
}
