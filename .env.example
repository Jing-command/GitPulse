# GitPulse 环境变量配置
# 复制此文件为 .env 并填写实际值

# ========================================
# 数据库配置（必需）
# ========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gitpulse?schema=public

# ========================================
# AI 大模型配置（用于代码分析）
# ========================================
# AI 提供商: openai, anthropic, yunwu
AI_PROVIDER=yunwu

# API 密钥（必需，用于 AI 代码分析）
# 如果没有配置，分析功能将只使用本地规则，不会有 AI 深度分析
AI_API_KEY=your-api-key-here

# API 基础 URL（可选，默认使用各提供商官方地址）
# AI_BASE_URL=https://api.openai.com/v1
AI_BASE_URL=https://api.yunwu.ai/v1

# AI 模型（可选）
# OpenAI: gpt-4, gpt-3.5-turbo
# Anthropic: claude-3-opus, claude-3-sonnet
# Yunwu: gemini-2.0-flash-exp
default
AI_MODEL=gemini-2.0-flash-exp

# ========================================
# JWT 配置（必需）
# ========================================
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=2h

# ========================================
# 服务配置（可选）
# ========================================
PORT=3002
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# ========================================
# GitHub OAuth（可选，用于 GitHub 登录）
# ========================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
